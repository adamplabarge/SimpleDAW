<Window x:Class="SimpleDAW.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleDAW"
        mc:Ignorable="d"
        Title="Simple Recorder" Height="800" Width="1200"
        Background="#1E1E1E">
    <Window.Resources>
        <local:PlusOneConverter x:Key="PlusOne"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#4A4A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#EEEEEE"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="1" CornerRadius="2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z" Fill="#EEEEEE"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,0,25,0"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <Popup x:Name="Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="#2D2D30" BorderBrush="#555555" BorderThickness="1"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Padding" Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="BorderBrush" Value="#4A4A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1F1F1F"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#141414"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#1B1B1B"/>
                                <Setter Property="Foreground" Value="#777777"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2B2B2B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TransportButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#4A4A4A"/>
        </Style>
        <Style x:Key="RecToggleButton" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="BorderBrush" Value="#4A4A4A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root" CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#8E1B1B"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C83232"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="#A32020"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Blue "M" mute toggle used by tracks and input channel meters -->
        <Style x:Key="MuteToggleButton" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#8FB8DE"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="BorderBrush" Value="#3A6EA5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root" CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#33465A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2D7DD2"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#5AA0E0"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="#3B8FE0"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark menu styling -->
        <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Margin="6,3" Background="#4A4A4A"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="DarkTopLevelMenuItem" TargetType="MenuItem">
            <Border x:Name="Border" Background="Transparent" Padding="10,5">
                <Grid>
                    <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                    <Popup x:Name="Popup" Placement="Bottom" AllowsTransparency="True"
                           Focusable="False" PopupAnimation="Fade"
                           IsOpen="{TemplateBinding IsSubmenuOpen}">
                        <Border Background="#252526" BorderBrush="#4A4A4A" BorderThickness="1">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </Popup>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="DarkSubmenuItem" TargetType="MenuItem">
            <Border x:Name="Border" Background="Transparent" Padding="20,5,20,5">
                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#094771"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#777777"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="Template" Value="{StaticResource DarkSubmenuItem}"/>
            <Style.Triggers>
                <Trigger Property="Role" Value="TopLevelHeader">
                    <Setter Property="Template" Value="{StaticResource DarkTopLevelMenuItem}"/>
                </Trigger>
                <Trigger Property="Role" Value="TopLevelItem">
                    <Setter Property="Template" Value="{StaticResource DarkTopLevelMenuItem}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="_Open…" Command="{Binding OpenProjectCommand}"/>
                <Separator/>
                <MenuItem Header="_Save" Command="{Binding SaveProjectCommand}"/>
                <MenuItem Header="Save _As…" Command="{Binding SaveProjectAsCommand}"/>
                <Separator/>
                <MenuItem Header="_Export Stereo Mix…" Command="{Binding MixdownCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExitClick"/>
            </MenuItem>
        </Menu>

        <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Transport + tempo -->
        <Border Grid.Row="0" Background="#252526" CornerRadius="6" Padding="10" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource TransportButton}" Content="⏮"
                        ToolTip="Back to start" Command="{Binding BackToStartCommand}"/>
                <Button Style="{StaticResource TransportButton}" Content="▶"
                        ToolTip="Play" Foreground="#7CFC7C" Command="{Binding PlayCommand}"/>
                <Button Style="{StaticResource TransportButton}" Content="⏺"
                        ToolTip="Record" Foreground="#FF6B6B" Command="{Binding RecordCommand}"/>
                <Button Style="{StaticResource TransportButton}" Content="■"
                    ToolTip="Stop" Command="{Binding StopCommand}"/>

                <TextBlock Text="Tempo (BPM)" Margin="24,0,6,0"/>
                <TextBox Width="60" VerticalContentAlignment="Center"
                         Text="{Binding Tempo, UpdateSourceTrigger=LostFocus, StringFormat=F1}"/>

                <CheckBox Content="Send MIDI clock" Foreground="#EEEEEE" VerticalAlignment="Center"
                          Margin="16,0,0,0" IsChecked="{Binding SendMidiClock}"
                          ToolTip="When unchecked, Play/Record run without sending a MIDI clock"/>

                <TextBlock Text="Rec pre-roll" Margin="24,0,6,0" VerticalAlignment="Center"/>
                <ComboBox Width="70" VerticalContentAlignment="Center"
                          ItemsSource="{Binding PreRollBeatsOptions}"
                          SelectedItem="{Binding PreRollBeats}"
                          ToolTip="Beats to record before the MIDI clock starts, so the first beat is fully captured"/>

                <CheckBox Content="Click" Foreground="#EEEEEE" VerticalAlignment="Center"
                          Margin="24,0,0,0" IsChecked="{Binding ClickEnabled}"
                          ToolTip="Play a metronome click on every beat during record and playback"/>
                <ComboBox Width="110" Margin="6,0,0,0" VerticalContentAlignment="Center"
                          ItemsSource="{Binding ClickAccentOptions}"
                          DisplayMemberPath="Label" SelectedValuePath="Value"
                          SelectedValue="{Binding ClickAccent}"
                          ToolTip="Which beats of the bar are accented (louder)"/>
                <Slider Width="90" Margin="6,0,0,0" VerticalAlignment="Center"
                        Minimum="0" Maximum="1" Value="{Binding ClickVolume}"
                        ToolTip="Click volume"/>

                <TextBlock Text="Sample rate" Margin="24,0,6,0"/>
                <ComboBox Width="90"
                          ItemsSource="{Binding SampleRateOptions}"
                          SelectedItem="{Binding SampleRate}"/>
            </StackPanel>
        </Border>

        <!-- Device selection -->
        <Border Grid.Row="1" Background="#252526" CornerRadius="6" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Audio input"/>
                    <ComboBox Width="240" Margin="6,0,24,0"
                              ItemsSource="{Binding AudioDevices}"
                              SelectedItem="{Binding SelectedAudioDevice}"/>

                    <TextBlock Text="Output"/>
                    <ComboBox Width="240" Margin="6,0,0,0"
                              ItemsSource="{Binding AudioOutputs}"
                              SelectedItem="{Binding SelectedAudioOutput}"
                              ToolTip="Where playback and monitoring are sent"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="MIDI clock out"/>
                    <ComboBox Width="200" Margin="6,0,24,0"
                              ItemsSource="{Binding MidiDevices}"
                              SelectedItem="{Binding SelectedMidiDevice}"/>

                    <Button Content="ASIO Panel" Padding="8,2" Margin="0,0,8,0"
                            Command="{Binding ShowAsioPanelCommand}"/>
                    <Button Content="Refresh" Padding="8,2"
                            Command="{Binding RefreshDevicesCommand}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Inputs" Margin="0,0,10,0" Foreground="#AAAAAA"/>
                    <ItemsControl ItemsSource="{Binding MasterInputMeters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Margin" Value="0,0,6,0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMain}" Value="True">
                                                    <Setter Property="Margin" Value="22,0,6,0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <ProgressBar Width="14" Height="46" Orientation="Vertical"
                                                 Minimum="0" Maximum="1" Value="{Binding Level, Mode=OneWay}"
                                                 Foreground="#4EC94E" Background="#1A1A1A"/>
                                    <TextBlock Text="{Binding Label}" FontSize="10"
                                               HorizontalAlignment="Center" Foreground="#AAAAAA"/>
                                    <ToggleButton Content="M" Width="22" Height="20" Margin="0,3,0,0"
                                                  FontSize="11"
                                                  IsChecked="{Binding IsMuted}"
                                                  ToolTip="Mute this input channel (meter keeps moving)"
                                                  Style="{StaticResource MuteToggleButton}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding AudioStatus}" Margin="16,0,0,0"
                               VerticalAlignment="Center" Foreground="#9CDCFE"/>
                    <TextBlock Text="{Binding MidiClockStatus}" Margin="16,0,0,0"
                               VerticalAlignment="Center" Foreground="#C586C0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Track toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="2,0,0,6">
            <Button Content="+ Add Track" Padding="10,4" Command="{Binding AddTrackCommand}"/>
            <Border Width="1" Background="#4A4A4A" Margin="12,2,12,2"/>
            <TextBlock Text="Zoom" Margin="0,0,6,0"/>
            <Button Content="−" Width="30" Padding="0,4" Command="{Binding ZoomOutCommand}"/>
            <Button Content="+" Width="30" Padding="0,4" Margin="6,0,0,0" Command="{Binding ZoomInCommand}"/>
            <TextBlock Text="Arm a track (REC) and assign its input channel to record from the Model 12."
                       Margin="16,0,0,0" Foreground="#AAAAAA"/>
        </StackPanel>

        <!-- Tracks -->
        <Border Grid.Row="3" Background="#252526" CornerRadius="6">
            <DockPanel>
                <ScrollBar DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4"
                           Minimum="0" Maximum="{Binding TimelineMaxSeconds}"
                           Value="{Binding TimelineOffsetSeconds}" ViewportSize="1"/>
                <!-- Single shared ruler: drawn once per frame instead of once per track. -->
                <local:TimelineRulerView DockPanel.Dock="Top" Height="18" Margin="12,4,12,0"
                                         PixelsPerSecond="{Binding PixelsPerSecond}"
                                         PlayheadSeconds="{Binding PlayheadSeconds}"
                                         ManualOffsetSeconds="{Binding TimelineOffsetSeconds}"
                                         IsFollowing="{Binding IsTransportActive}"/>
                <ListBox ItemsSource="{Binding Tracks}" SelectedItem="{Binding SelectedTrack}"
                         Background="Transparent" BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2D2D30" CornerRadius="4" Padding="8" Margin="4">
                            <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" Text="{Binding Name}"
                                         VerticalContentAlignment="Center" Margin="0,0,10,0"/>

                                <ToggleButton Grid.Column="1" Content="REC" Width="46" Height="30"
                                              Margin="0,0,10,0" IsChecked="{Binding IsArmed}"
                                              ToolTip="Arm for recording"
                                              Style="{StaticResource RecToggleButton}"/>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0">
                                    <TextBlock Text="In" Margin="0,0,4,0" Foreground="#EEEEEE"/>
                                    <ComboBox Width="78"
                                              ItemsSource="{Binding DataContext.AvailableInputChannels, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedValuePath="Index"
                                              SelectedValue="{Binding InputChannel}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}" Foreground="#EEEEEE"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <ToggleButton Grid.Column="3" Content="M" Width="30" Height="30"
                                              VerticalAlignment="Center" Margin="0,0,10,0"
                                              IsChecked="{Binding IsMuted}"
                                              ToolTip="Mute this track"
                                              Style="{StaticResource MuteToggleButton}"/>

                                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="0,0,10,0">
                                    <TextBlock Text="Vol" Margin="0,0,4,0" Foreground="#EEEEEE"/>
                                    <Slider Width="90" Minimum="0" Maximum="1"
                                            VerticalAlignment="Center" Value="{Binding Volume}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="0,0,10,0">
                                    <TextBlock Text="Pan" Margin="0,0,4,0" Foreground="#EEEEEE"/>
                                    <Slider Width="90" Minimum="-1" Maximum="1"
                                            VerticalAlignment="Center" Value="{Binding Pan}"
                                            ToolTip="Left / Right pan (centre = 0)"/>
                                </StackPanel>

                                <ProgressBar Grid.Column="6" Height="16" Minimum="0" Maximum="1"
                                             Value="{Binding Level, Mode=OneWay}"
                                             Foreground="#4EC94E" Background="#1A1A1A"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>

                                <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DurationText}" FontSize="11"
                                               Foreground="#AAAAAA" VerticalAlignment="Center"
                                               Margin="0,0,6,0" ToolTip="Recorded length (m:ss.d)"/>
                                    <TextBlock Text="●" FontSize="16"
                                               ToolTip="Has recorded audio" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#555555"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAudio}" Value="True">
                                                        <Setter Property="Foreground" Value="#4EC94E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <Button Grid.Column="8" Content="✕" Width="28" Height="28"
                                        VerticalAlignment="Center" Margin="10,0,0,0"
                                        ToolTip="Remove this track"
                                        Foreground="#FF9A9A"
                                        Command="{Binding DataContext.RemoveTrackCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                            <local:WaveformView Height="60" Margin="0,8,0,0"
                                                Buffer="{Binding Waveform}"
                                                PixelsPerSecond="{Binding DataContext.PixelsPerSecond, RelativeSource={RelativeSource AncestorType=Window}}"
                                                PlayheadSeconds="{Binding DataContext.PlayheadSeconds, RelativeSource={RelativeSource AncestorType=Window}}"
                                                ManualOffsetSeconds="{Binding DataContext.TimelineOffsetSeconds, RelativeSource={RelativeSource AncestorType=Window}}"
                                                IsFollowing="{Binding DataContext.IsTransportActive, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            </DockPanel>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="4" Margin="2,8,0,0" Foreground="#888888"
                   Text="{Binding RecordDirectory, StringFormat=Recordings folder: {0}}"/>
        </Grid>
    </DockPanel>
</Window>
